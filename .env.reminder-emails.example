# ============================================
# Reminder Email Notifications Configuration
# ============================================
# Copy these variables to your .env.local file

# ============================================
# SMTP Configuration (Required)
# ============================================

# Gmail Example (Easiest for testing)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=Smart Calculator Reminders

# SendGrid Example
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key
# SMTP_FROM=noreply@yourdomain.com
# SMTP_FROM_NAME=Smart Calculator Reminders

# AWS SES Example
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-ses-smtp-username
# SMTP_PASSWORD=your-ses-smtp-password
# SMTP_FROM=noreply@yourdomain.com
# SMTP_FROM_NAME=Smart Calculator Reminders

# ============================================
# Cron Job Security (Optional but Recommended)
# ============================================
# Generate a random secret: openssl rand -hex 32
CRON_SECRET=your-random-secret-key-here

# ============================================
# Gmail Setup Instructions
# ============================================
# 1. Go to https://myaccount.google.com/security
# 2. Enable "2-Step Verification"
# 3. Go to "App passwords" (search for it)
# 4. Select "Mail" and your device
# 5. Copy the 16-character password
# 6. Use it as SMTP_PASSWORD above
# 7. DO NOT use your regular Gmail password!

# ============================================
# Testing
# ============================================
# After adding these variables:
# 1. Run: npm run test:reminder-emails
# 2. Create a test reminder in your app
# 3. Check your email inbox (and spam folder)

# ============================================
# Production Notes
# ============================================
# - Use a dedicated email service (SendGrid, AWS SES)
# - Set up SPF, DKIM, and DMARC records
# - Monitor email delivery rates
# - Never commit this file to version control
# - Use different credentials for dev/staging/prod
