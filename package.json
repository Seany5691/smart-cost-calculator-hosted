{
  "name": "smart-cost-calculator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "analyze": "ANALYZE=true npm run build",
    "deploy": "npm run build && echo 'Build successful! Ready for VPS deployment.'",
    "test-db": "node -e \"require('./src/lib/postgresql-connection').testConnection()\"",
    "setup-db": "psql -h localhost -U smartcost_user -d smartcost_vps -f database/schema.sql",
    "export-supabase": "node scripts/export-supabase-data.js",
    "import-postgres": "node scripts/import-to-postgresql.js",
    "migrate-data": "npm run export-supabase && npm run import-postgres"
  },
  "dependencies": {
    "@sparticuz/chromium": "^141.0.0",
    "@supabase/supabase-js": "^2.39.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.536.0",
    "next": "15.4.5",
    "pdf-lib": "^1.17.1",
    "pg": "^8.11.3",
    "puppeteer": "^24.26.1",
    "puppeteer-core": "^24.26.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-window": "^2.2.1",
    "tailwind-merge": "^3.3.1",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^15.5.4",
    "@types/node": "^20",
    "@types/pg": "^8.10.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-window": "^1.8.8",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "15.4.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
